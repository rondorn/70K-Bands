# Google Play Console API Credentials
#
# Solo / small accounts: "API access" may not appear as a top-level menu. Use instead:
#   Play Console → Users and permissions → Invite new users
#   Enter the service account email (from GCP: …@….iam.gserviceaccount.com)
#   Grant app access + permissions to create/edit releases (or Admin on that app).
# Also enable "Google Play Android Developer API" on the same GCP project as the key.
# Docs: https://developers.google.com/android-publisher/getting_started
#
# Relative paths are resolved from the andriod/ folder (not the git repo root).
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=./fastlane/google-play-api-key.json

# Android Signing Configuration
# Path to your keystore file
ANDROID_KEYSTORE_PATH=./release-keystore.jks
ANDROID_KEY_ALIAS=your-key-alias
ANDROID_KEY_PASSWORD=your-key-password
ANDROID_STORE_PASSWORD=your-store-password

# Android release_full_automation.sh does not use Google Cloud Translation or DeepL.
# Play changelogs: default_language from apps_config.json only (en-US).

# Notification settings (optional)
#SLACK_WEBHOOK_URL=YOUR_SLACK_WEBHOOK_URL

# QA UI walkthrough (scripts/android_qa_ui_walkthrough.sh) — optional
# EMULATOR_AVD=Pixel_8_API_35
# ANDROID_SERIAL=emulator-5554
# QA_UI_SKIP_AUTO_AVD=1
# ANDROID_FLAVOR=bands70k
# ANDROID_APP_ID=com.Bands70k
