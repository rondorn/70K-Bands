<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="#1C1C1E">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Suite attribution (populated at runtime) -->
        <TextView
            android:id="@+id/suite_registry_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="#8E8E93"
            android:paddingBottom="12dp" />

        <!-- About Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/about"
            android:textSize="34sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:paddingBottom="20dp" />

        <!-- Main Description (festival/app names injected from festival.json) -->
        <TextView
            android:id="@+id/about_description1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="17sp"
            android:textColor="#FFFFFF"
            android:lineSpacingMultiplier="1.4"
            android:paddingBottom="16dp" />

        <TextView
            android:id="@+id/about_description2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="17sp"
            android:textColor="#FFFFFF"
            android:lineSpacingMultiplier="1.4"
            android:paddingBottom="16dp" />

        <TextView
            android:id="@+id/about_description3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="17sp"
            android:textColor="#FFFFFF"
            android:lineSpacingMultiplier="1.4"
            android:paddingBottom="16dp" />

        <TextView
            android:id="@+id/about_description4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="17sp"
            android:textColor="#FFFFFF"
            android:lineSpacingMultiplier="1.4"
            android:paddingBottom="16dp" />

        <TextView
            android:id="@+id/about_description5"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="17sp"
            android:textColor="#FFFFFF"
            android:lineSpacingMultiplier="1.4"
            android:paddingBottom="16dp" />

        <!-- Copyright -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/about_copyright"
            android:textSize="13sp"
            android:textColor="#8E8E93"
            android:paddingTop="10dp"
            android:paddingBottom="20dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="#3A3A3C"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="20dp" />

        <!-- The Team Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/about_the_team"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:paddingBottom="16dp" />

        <!-- Team Members (populated from festival.json) -->
        <LinearLayout
            android:id="@+id/about_team_members"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="20dp" />

        <!-- Bottom Spacing -->
        <View
            android:layout_width="match_parent"
            android:layout_height="30dp" />

    </LinearLayout>
</ScrollView>
