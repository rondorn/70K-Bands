<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1C1C1E">

    <ScrollView
        android:id="@+id/wizard_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:paddingTop="88dp"
            android:paddingEnd="24dp"
            android:paddingBottom="24dp">

        <TextView
            android:id="@+id/wizard_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/plan_your_schedule"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:paddingTop="24dp"
            android:paddingBottom="32dp" />

            <!-- Step 0: Intro (matches iOS first screen) -->
            <LinearLayout
                android:id="@+id/wizard_step_intro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible"
                android:padding="24dp"
                android:minHeight="180dp"
                android:background="#1C1C1E">
                <TextView
                    android:id="@+id/wizard_intro_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/plan_schedule_intro"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:lineSpacingMultiplier="1.2"
                    android:paddingTop="8dp"
                    android:paddingBottom="16dp" />
            </LinearLayout>

            <!-- Step 1: Unknown bands (Must/Might/Wont not set) -->
            <LinearLayout
                android:id="@+id/wizard_step_unknown_bands"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:padding="24dp"
                android:background="#1C1C1E">
                <TextView
                    android:id="@+id/wizard_unknown_message"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:paddingBottom="8dp" />
                <TextView
                    android:id="@+id/wizard_unknown_hint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#B0B0B0"
                    android:textSize="14sp"
                    android:paddingBottom="12dp"
                    android:visibility="gone" />
                <ScrollView
                    android:id="@+id/wizard_unknown_list_scroll"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxHeight="240dp"
                    android:visibility="gone">
                    <LinearLayout
                        android:id="@+id/wizard_unknown_list"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />
                </ScrollView>
                <LinearLayout
                    android:id="@+id/wizard_unknown_buttons"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="16dp"
                    android:visibility="gone">
                    <Button
                        android:id="@+id/wizard_unknown_treat_wont"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/unknown_bands_treat_as_wont"
                        android:layout_marginEnd="8dp" />
                    <Button
                        android:id="@+id/wizard_unknown_next"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/Next"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#007AFF" />
                </LinearLayout>
                <Button
                    android:id="@+id/wizard_unknown_ok"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/Ok"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Step 2: Latest show cutoff (was step 1) -->
            <LinearLayout
                android:id="@+id/wizard_step_latest_show"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:padding="24dp"
                android:background="#1C1C1E">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/latest_show_cutoff"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:paddingBottom="8dp" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/latest_show_cutoff_hint"
                    android:textColor="#B0B0B0"
                    android:textSize="14sp"
                    android:paddingBottom="12dp" />
                <Spinner
                    android:id="@+id/wizard_latest_show_spinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="48dp"
                    android:popupBackground="@drawable/spinner_popup_background_dark" />
            </LinearLayout>

            <!-- Step: Unofficial / Cruiser Organized (only if any exist for Must bands) -->
            <LinearLayout
                android:id="@+id/wizard_step_unofficial"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:padding="24dp"
                android:background="#1C1C1E">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/aischedule_unofficial_question"
                    android:textColor="#FFFFFF"
                    android:paddingBottom="4dp" />
                <TextView
                    android:id="@+id/wizard_unofficial_hint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/aischedule_unofficial_checklist_hint"
                    android:textColor="#B0B0B0"
                    android:textSize="14sp"
                    android:paddingBottom="8dp" />
                <Button
                    android:id="@+id/wizard_unofficial_all"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/aischedule_checklist_all"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#007AFF"
                    android:layout_marginBottom="8dp" />
                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxHeight="280dp">
                    <LinearLayout
                        android:id="@+id/wizard_unofficial_list"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />
                </ScrollView>
            </LinearLayout>

            <!-- Step: Meet and Greet (checklist, Must bands only) -->
            <LinearLayout
                android:id="@+id/wizard_step_meet_greet"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:padding="24dp"
                android:background="#1C1C1E">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/aischedule_meet_greet_question"
                    android:textColor="#FFFFFF"
                    android:paddingBottom="4dp" />
                <TextView
                    android:id="@+id/wizard_meet_greet_hint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/aischedule_meet_greet_checklist_hint"
                    android:textColor="#B0B0B0"
                    android:textSize="14sp"
                    android:paddingBottom="8dp" />
                <Button
                    android:id="@+id/wizard_meet_greet_all"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/aischedule_checklist_all"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#007AFF"
                    android:layout_marginBottom="8dp" />
                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxHeight="280dp">
                    <LinearLayout
                        android:id="@+id/wizard_meet_greet_list"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />
                </ScrollView>
            </LinearLayout>

            <!-- Step 4: Clinics (checklist) -->
            <LinearLayout
                android:id="@+id/wizard_step_clinics"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:padding="24dp"
                android:background="#1C1C1E">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/clinics_choice"
                    android:textColor="#FFFFFF"
                    android:paddingBottom="4dp" />
                <TextView
                    android:id="@+id/wizard_clinics_hint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/aischedule_clinics_checklist_hint"
                    android:textColor="#B0B0B0"
                    android:textSize="14sp"
                    android:paddingBottom="8dp" />
                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxHeight="280dp">
                    <LinearLayout
                        android:id="@+id/wizard_clinics_list"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />
                </ScrollView>
            </LinearLayout>

            <!-- Step 5: Special Events (checklist, only if schedule has special events) -->
            <LinearLayout
                android:id="@+id/wizard_step_special_events"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:padding="24dp"
                android:background="#1C1C1E">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/aischedule_special_events_header"
                    android:textColor="#FFFFFF"
                    android:paddingBottom="4dp" />
                <TextView
                    android:id="@+id/wizard_special_events_hint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/aischedule_special_events_hint"
                    android:textColor="#B0B0B0"
                    android:textSize="14sp"
                    android:paddingBottom="8dp" />
                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxHeight="280dp">
                    <LinearLayout
                        android:id="@+id/wizard_special_events_list"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />
                </ScrollView>
            </LinearLayout>

            <!-- Step 6: Building (progress) -->
            <LinearLayout
                android:id="@+id/wizard_step_building"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:padding="24dp"
                android:background="#1C1C1E">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/building_schedule"
                    android:textColor="#FFFFFF"
                    android:paddingBottom="8dp" />
                <ProgressBar
                    android:id="@+id/wizard_progress"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:indeterminate="true" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Fixed bottom bar: Cancel, Back, Next (static while content scrolls) -->
    <LinearLayout
        android:id="@+id/wizard_bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:paddingStart="16dp"
        android:paddingEnd="24dp"
        android:background="#1C1C1E"
        android:elevation="8dp">

        <Button
            android:id="@+id/wizard_cancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/Cancel" />

        <Button
            android:id="@+id/wizard_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="@string/navigation_back"
            android:visibility="gone" />

        <Button
            android:id="@+id/wizard_next"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="@string/Next"
            android:textColor="#FFFFFF"
            android:backgroundTint="#007AFF"
            android:focusable="true"
            android:clickable="true" />
    </LinearLayout>
</LinearLayout>
