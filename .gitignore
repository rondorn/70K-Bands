*.d
*.dia
*.o
*.swiftdeps
*.xcbkptlist
*.xcuserstate
*.swiftconstvalues
*.hprof
andriod/build/reports/configuration-cache
swift/.env.example
swift/.env.swp
swift/apps_config.json
