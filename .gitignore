# Swift — Firebase client configs (contain API keys; download from Firebase console per machine)
swift/GoogleService-Info*
swift/**/GoogleService-Info*

# Android — Firebase client configs (download from Firebase console per flavor)
andriod/**/google-services*.json

# Android — Google Play Console API (service account JSON for release/check-in)
andriod/fastlane/google-play-api-key.json

# Android — local SDK paths & build artifacts (must not be committed)
andriod/local.properties
andriod/app/local.properties
andriod/app/app-release.apk

# Markdown: ignore all except README.md (also see ~/.gitignore_global)
*.md
!README.md
!**/README.md
